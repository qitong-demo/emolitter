{
  "name": "emolitter",
  "version": "0.4.0",
  "description": "A local-first creative CLI with a Chinese menu that turns desktop activity into literary letters.",
  "type": "module",
  "bin": {
    "emo": "bin/emo.js"
  },
  "files": [
    "bin",
    "src",
    "README.md"
  ],
  "scripts": {
    "start": "node ./bin/emo.js",
    "check": "node ./bin/emo.js --help",
    "sample": "node ./bin/emo.js sample --stdout",
    "showcase": "node ./bin/emo.js showcase",
    "menu": "node ./bin/emo.js"
  },
  "keywords": [
    "cli",
    "letter",
    "creative-tool",
    "digital-diary",
    "local-first",
    "desktop",
    "chinese-cli"
  ],
  "author": "qitong-demo",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "get-windows": "^9.3.0",
    "node-global-key-listener": "^0.3.0"
  }
}
